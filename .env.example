DATABASE_URL="postgresql://postgres:postgres@localhost:5432/occ_handover"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/occ_handover"
# Optional Prisma pool tuning for long-lived processes.
DATABASE_CONNECTION_LIMIT="20"
# DATABASE_POOL_TIMEOUT="20"

# HMAC secret used by the backend to validate signed auth headers (X-OCC-AUTH-*).
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Backend port (defaults to 4000).
# PORT=4000

# Rate limiting (per identity, in-process token bucket).
# See backend/src/middleware/rate-limit.middleware.ts and
# docs/AUTH_MIGRATION.md (gap #3) for context.
RATE_LIMIT_CAPACITY="100"
RATE_LIMIT_REFILL_INTERVAL_MS="60000"
RATE_LIMIT_MAX_IDENTITIES="10000"
